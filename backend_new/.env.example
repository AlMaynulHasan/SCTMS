# ─── Server Configuration ──────────────────────────
PORT=5000
NODE_ENV=production

# ─── Database (SQL Server) ────────────────────────
# লোকাল হোস্টের বদলে অনলাইন সার্ভার লিঙ্ক এখানে বসবে
DB_SERVER=your_online_db_server_address
DB_PORT=1433
DB_NAME=SCTMS
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# ─── Authentication (JWT) ─────────────────────────
JWT_SECRET=your_super_secret_random_string
JWT_EXPIRES_IN=7d

# ─── Security & CORS ──────────────────────────────
# এখানে আপনার ফ্রন্টএন্ড ইউআরএল (যেমন GitHub Pages লিঙ্ক) দিতে হবে
ALLOWED_ORIGINS=https://your-username.github.io,http://localhost:5500

# ─── Email (Brevo SMTP) ───────────────────────────
EMAIL_USER=your_smtp_user
EMAIL_PASS=your_smtp_password
EMAIL_FROM=your_email@example.com
